# Copy to `.env.docker` for `docker compose up` (gitignored).
# Values are non-secret placeholders; replace for real deployments.

NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@db:5432/pg_manager?schema=public
JWT_SECRET=dev-docker-jwt-secret-min-32-chars!!
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=info

TWILIO_ACCOUNT_SID=AC00000000000000000000000000000000
TWILIO_AUTH_TOKEN=00000000000000000000000000000000
TWILIO_PHONE_NUMBER=+10000000000
# E.164 or whatsapp:+E164 — normalized before calling Twilio
TWILIO_WHATSAPP_NUMBER=whatsapp:+10000000000

# Development: print OTP in API logs instead of sending (NODE_ENV=development only)
# AUTH_OTP_CONSOLE=1

CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=00000000000000000000000000000000
