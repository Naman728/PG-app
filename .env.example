# --- Frontend (Vite) / Netlify / CI ---
# Set at BUILD time (inlined into the bundle). Required for any non-localhost deploy.
# VITE_API_URL=https://your-api.example.com/api/v1

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pg_manager?schema=public
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
# Twilio — required for real OTP. Trial accounts: SMS only to verified numbers; WhatsApp needs sandbox opt-in.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164, e.g. +15551234567 (do not double-prefix with whatsapp:)
TWILIO_PHONE_NUMBER=
# E.164 or whatsapp:+1555… — both are normalized before calling Twilio
TWILIO_WHATSAPP_NUMBER=

# Local dev without Twilio delivery: set AUTH_OTP_CONSOLE=1 (development only). OTP is printed in API logs, not sent.
# AUTH_OTP_CONSOLE=1
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
PORT=3000
FRONTEND_URL=http://localhost:5173
# Comma-separated CORS origins (overrides FRONTEND_URL for multiple frontends).
# Must include the exact browser origin (scheme + host + port) of the SPA, or sign-in fails with a network/CORS error when cookies are sent.
# CORS_ORIGINS=http://localhost:5173,https://app.example.com,https://my-app.vercel.app
# Optional: allow every Vercel preview URL (https://*.vercel.app) in addition to the list above — use only if you accept that tradeoff.
# CORS_ALLOW_VERCEL_PREVIEW=true
# LOG_LEVEL=info
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14
NODE_ENV=development

# Optional seed (npm run db:seed -w backend)
# Option A — email/password owner (matches app login):
# SEED_OWNER_EMAIL=owner@example.com
# SEED_OWNER_PASSWORD=your-secure-password
# Option B — legacy phone-only owner (no password; cannot use email login until password is set):
# SEED_OWNER_PHONE=+9198XXXXXXXX
# SEED_ORG_NAME=Demo PG — Indiranagar
# SEED_DEMO=1 — also create demo floors/rooms/beds when possible
# SEED_TENANT_PHONE=+9198YYYYYYYY — demo tenant (must differ from owner phone if used); assigns first vacant bed
